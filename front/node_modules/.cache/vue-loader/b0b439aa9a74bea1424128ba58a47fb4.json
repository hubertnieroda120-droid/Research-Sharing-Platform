lass=\"input-container\">\n\t\t\t     <input v-model=\"ruleForm.xueyuanzhanghao\" class=\"input\" type=\"text\" placeholder=\"科研机构账号\">\n\t\t\t   </div>\n\t\t\t </div> -->\n\t\t\t<el-form-item label=\"科研机构账号\" class=\"input\" v-if=\"tableName=='xueyuan'\">\n\t\t\t  <el-input v-model=\"ruleForm.xueyuanzhanghao\" autocomplete=\"off\" placeholder=\"科研机构账号\"  />\n\t\t\t</el-form-item>\n\t\t\t<!-- <div v-if=\"tableName=='xueyuan'\" class=\"input-group\">\n\t\t\t   <div class=\"label\">密码</div>\n\t\t\t   <div class=\"input-container\">\n\t\t\t     <input v-model=\"ruleForm.mima\" class=\"input\" type=\"text\" placeholder=\"密码\">\n\t\t\t   </div>\n\t\t\t </div> -->\n\t\t\t<el-form-item label=\"密码\" class=\"input\" v-if=\"tableName=='xueyuan'\">\n\t\t\t  <el-input v-model=\"ruleForm.mima\" autocomplete=\"off\" placeholder=\"密码\" type=\"password\"#elsetype=\"text\" />\n\t\t\t</el-form-item>\n\t\t\t<el-form-item label=\"确认密码\" class=\"input\" v-if=\"tableName=='xueyuan'\">\n\t\t\t  <el-input v-model=\"ruleForm.mima2\" autocomplete=\"off\" placeholder=\"确认密码\" type=\"password\"/>\n\t\t\t</el-form-item>\n\n\t\t\t<!-- <div v-if=\"tableName=='xueyuan'\" class=\"input-group\">\n\t\t\t   <div class=\"label\">科研机构名称</div>\n\t\t\t   <div class=\"input-container\">\n\t\t\t     <input v-model=\"ruleForm.xueyuanmingcheng\" class=\"input\" type=\"text\" placeholder=\"科研机构名称\">\n\t\t\t   </div>\n\t\t\t </div> -->\n\t\t\t<el-form-item label=\"科研机构名称\" class=\"input\" v-if=\"tableName=='xueyuan'\">\n\t\t\t  <el-input v-model=\"ruleForm.xueyuanmingcheng\" autocomplete=\"off\" placeholder=\"科研机构名称\"  />\n\t\t\t</el-form-item>\n\t\t\t<!-- <div v-if=\"tableName=='xueyuan'\" class=\"input-group\">\n\t\t\t   <div class=\"label\">负责人</div>\n\t\t\t   <div class=\"input-container\">\n\t\t\t     <input v-model=\"ruleForm.fuzeren\" class=\"input\" type=\"text\" placeholder=\"负责人\">\n\t\t\t   </div>\n\t\t\t </div> -->\n\t\t\t<el-form-item label=\"负责人\" class=\"input\" v-if=\"tableName=='xueyuan'\">\n\t